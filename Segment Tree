// Basic implementation
#include <bits/stdc++.h>
using namespace std;
const int maxN = 1e5 + 9;
int a[maxN], tree[4 * maxN];
void build(int node, int b, int e)//O(n)
{
    if (b == e)
    {
        tree[node] = a[b];
        return;
    }
    int mid = (b + e) / 2, left = 2 * node, right = 2 * node + 1;
    build(left, b, mid);
    build(right, mid + 1, e);
    tree[node] = tree[left] + tree[right];
}
void update(int node,int b,int e,int i,int val)//O(logn)
{
    if(i<b || i>e)// ata holo out...node er range jodi bhaire takhe tahole jawar dorkar nai
    {
        return;
    }
    if(b==e)// ata holo in ..mane amder update er range peye gechi akon val upadate korbo 
    {
        tree[node]=val;
        return;
    }
    // ata holo intersection ..to amra 2 ta child ai jabo
    int mid = (b + e) / 2, left = 2 * node, right = 2 * node + 1;
    update(left, b, mid,i,val);
    update(right, mid + 1,e,i,val);
    tree[node] = tree[left] + tree[right];
}
int query(int node,int b,int e,int l,int r)//O(logn)
{
    if(e<l || r<b)
    {
        return 0;
    }
    if(b<=l && e<=r)
    {
        return tree[node];
    }
    int mid = (b + e) / 2, left = 2 * node, right = 2 * node + 1;
    return query(left,b,mid,l,r)+query(right,mid+1,e,l,r);
}
